# data (never commit raw data)
data/raw/

# data/processed: ignore everything except serve-time model + feature artifacts
data/processed/*
!data/processed/*.pkl
!data/processed/*.parquet

# data/vector_store: track the full ChromaDB directory so Streamlit Cloud can
# serve without a cold-start rebuild. data/rag_source/ (the source .txt blurbs)
# is not ignored and also tracked for transparency.
data/vector_store/*
!data/vector_store/**

# env
.env
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS
.DS_Store

# Editors
.vscode/
.idea/
